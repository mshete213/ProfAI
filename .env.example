# Database
DATABASE_URL=postgresql+psycopg2://edtech:edtech_dev@postgres:5432/edtech
DATABASE_URL_LOCAL=postgresql+psycopg2://edtech:edtech_dev@localhost:5432/edtech

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (for embeddings)
OPENAI_API_KEY=your-openai-api-key

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=edtech-prod
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Auth
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Internal MCP <-> backend auth
INTERNAL_MCP_API_KEY=change-me-internal-mcp-key

# Backend (used by MCP server + frontend)
BACKEND_INTERNAL_URL=http://backend:8000
BACKEND_PUBLIC_URL=http://localhost:8000

# Frontend
FRONTEND_PUBLIC_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# RAG tuning
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.72
HISTORY_TOKEN_BUDGET=4000

# Encryption key for storing Canvas/Drive credentials at rest (Fernet, base64-encoded 32 bytes)
CREDENTIALS_ENCRYPTION_KEY=your-fernet-key-here

# Canvas webhook receiver public URL (must be reachable by Canvas)
CANVAS_WEBHOOK_PUBLIC_URL=https://your-public-domain.com/webhooks/canvas
